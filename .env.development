# 本地开发环境变量
# 使用方法: 复制此文件内容到 .env 并重启开发服务器

# 本地 PostgreSQL (Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bunn_db"

# 本地 Redis (Docker)
# 使用 docker compose up -d redis 启动本地 Redis
REDIS_URL="redis://localhost:6379"

# Java 后端 (bunn-backend)，用于 /api/ai/chat 代理
JAVA_BACKEND_URL="http://localhost:8080"

# 其他配置保持与 .env 相同
